# Copy to .env and adjust. The gateway loads .env on startup (values already set
# in the environment take precedence).

# --- general ---------------------------------------------------------------
ENV=dev                       # dev | staging | prod (prod enforces real secrets)

# --- http server -----------------------------------------------------------
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=20s
MAX_BODY_BYTES=1048576         # 1 MiB request body cap

# --- redis -----------------------------------------------------------------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- postgres --------------------------------------------------------------
DATABASE_URL=postgres://gateway:gateway@localhost:5432/gateway?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=30m

# --- worker pool -----------------------------------------------------------
WORKER_COUNT=8
WORKER_POLL_TIMEOUT=5s          # BLPOP timeout per poll
JOB_MAX_RETRIES=5
RETRY_BASE_DELAY=500ms
RETRY_MAX_DELAY=30s

# --- rate limiting + backpressure ------------------------------------------
GLOBAL_RATE_RPS=2000            # process-wide sustained rate
GLOBAL_RATE_BURST=4000
ROUTE_RATE_RPS=50               # per-client sustained rate
ROUTE_RATE_BURST=100
QUEUE_MAX_DEPTH=10000           # load-shed (503) when total queue depth >= this
IDEMPOTENCY_TTL=24h
QR_DEDUP_TTL=10s

# --- security --------------------------------------------------------------
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=ingress-api-gateway
PAYMENT_HMAC_SECRET=whsec_dev_secret_change_me

# --- logging ---------------------------------------------------------------
LOG_LEVEL=info                  # debug | info | warn | error
LOG_FORMAT=json                 # json | console
